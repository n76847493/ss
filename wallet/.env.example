# ====== Telegram ======
BOT_TOKEN=replace-with-token-from-BotFather
# Comma-separated Telegram user IDs that get admin access in the bot
ADMIN_TELEGRAM_IDS=123456789

# ====== Admin web panel (FastAPI) ======
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080

# ====== Database / Redis ======
DATABASE_URL=postgresql+asyncpg://wallet:wallet@db:5432/wallet
DATABASE_URL_SYNC=postgresql+psycopg2://wallet:wallet@db:5432/wallet
REDIS_URL=redis://redis:6379/0

# ====== Master seed encryption ======
# 32-byte urlsafe-base64 Fernet key. Generate locally with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=replace-with-fernet-key
# BIP39 mnemonic for the operator HD wallet. Generate offline with `python -m app.crypto.seed gen`.
# IMPORTANT: store the *encrypted* blob (output of `app.crypto.seed encrypt`) here, never the raw mnemonic.
MASTER_SEED_ENCRYPTED=replace-with-encrypted-seed

# ====== Operator fee + cold storage ======
# When a single deposit address accumulates more than SWEEP_THRESHOLD_USD,
# the worker sweeps it to the hot wallet. When the hot wallet exceeds
# COLD_THRESHOLD_USD, surplus is sent to the configured cold address per chain.
SWEEP_THRESHOLD_USD=25
COLD_THRESHOLD_USD=10000

# Optional per-chain cold-storage addresses (empty disables cold sweeps)
COLD_ADDR_BTC=
COLD_ADDR_ETH=
COLD_ADDR_BSC=
COLD_ADDR_POLYGON=
COLD_ADDR_TRON=
COLD_ADDR_TON=
COLD_ADDR_SOL=

# ====== Withdrawal limits (anti-fraud) ======
WITHDRAW_DAILY_LIMIT_USD=5000
WITHDRAW_PER_TX_LIMIT_USD=2000
WITHDRAW_REQUIRE_2FA_OVER_USD=100

# ====== Chain RPC endpoints (leave empty to disable that chain's online features) ======
# Bitcoin: a Bitcoin Core RPC URL or compatible (Blockstream Esplora is also auto-detected)
BTC_RPC_URL=
BTC_NETWORK=mainnet
BTC_ESPLORA_URL=https://blockstream.info/api

